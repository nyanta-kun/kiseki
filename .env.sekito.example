# sekito本番環境用 .env テンプレート
# このファイルをコピーして .env を作成し、各値を設定してください
# cp .env.sekito.example .env

# --- DB (sekito-stable.com PostgreSQL) ---
# Dockerコンテナからホストのポートに接続するためhost.docker.internalを使用
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=hrdb
DB_USER=hrdb_user
DB_PASSWORD=your_password_here
DB_SCHEMA=keiba

# --- JRA-VAN ---
JRAVAN_SID=your-jravan-sid-here

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=production
DEBUG=false

# --- Windows Agent → sekito Backend URL ---
# Windows Agent (Mac) がデータ投入に使用するURL
BACKEND_URL=https://sekito-stable.com/kiseki

# --- Betting Limits ---
BET_MAX_PER_DAY=30000
BET_MAX_PER_RACE=5000
BET_MAX_PER_TICKET=1000
BET_MIN_EXPECTED_VALUE=1.20
BET_MAX_CONSECUTIVE_LOSSES=10

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/kiseki.log

# -------------------------------------------------------------------
# 認証（Auth.js / NextAuth.js）
# -------------------------------------------------------------------
# JWT暗号化キー: openssl rand -base64 32 で生成
AUTH_SECRET=
# 全ユーザー共通の合言葉（ログイン画面で入力するパスワード）
AUTH_PASSWORD=
# Google OAuth クライアントID（Google Cloud Console で取得）
AUTH_GOOGLE_ID=
# Google OAuth クライアントシークレット
AUTH_GOOGLE_SECRET=
# 本番URL（basePath込み）例: https://sekito-stable.com/kiseki
NEXTAUTH_URL=https://sekito-stable.com/kiseki
