# kiseki 環境変数テンプレート
# このファイルを .env にコピーして各値を設定すること
# cp .env.example .env

# -------------------------------------------------------------------
# VPS PostgreSQL 接続情報
# -------------------------------------------------------------------
DB_HOST=your-vps-hostname-or-ip
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=keiba_app
DB_PASSWORD=your_secure_password
DB_SCHEMA=keiba

# -------------------------------------------------------------------
# JRA-VAN Data Lab 利用キー
# -------------------------------------------------------------------
JRAVAN_SID=your-jravan-sid-here

# -------------------------------------------------------------------
# FastAPI 設定
# -------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
DEBUG=true

# Windows Agent → Mac FastAPI の接続URL
# Parallels環境では host.internal でMac側に接続できる
BACKEND_URL=http://host.internal:8000

# Windows Agentとの共有APIキー（空の場合は認証スキップ）
CHANGE_NOTIFY_API_KEY=

# -------------------------------------------------------------------
# 馬券安全設定
# -------------------------------------------------------------------
BET_MAX_PER_DAY=30000
BET_MAX_PER_RACE=5000
BET_MAX_PER_TICKET=1000
BET_MIN_EXPECTED_VALUE=1.20
BET_MAX_CONSECUTIVE_LOSSES=10

# -------------------------------------------------------------------
# ログ設定
# -------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/kiseki.log

# -------------------------------------------------------------------
# 認証（Auth.js / NextAuth.js）
# -------------------------------------------------------------------
# JWT暗号化キー: openssl rand -base64 32 で生成
AUTH_SECRET=
# 全ユーザー共通の合言葉（ログイン画面で入力するパスワード）
AUTH_PASSWORD=
# Google OAuth クライアントID（Google Cloud Console で取得）
AUTH_GOOGLE_ID=
# Google OAuth クライアントシークレット
AUTH_GOOGLE_SECRET=
# 本番URL（basePath込み）例: https://sekito-stable.com/kiseki
NEXTAUTH_URL=
